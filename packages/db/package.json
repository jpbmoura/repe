{
  "name": "@repe/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed/run.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.3"
  }
}

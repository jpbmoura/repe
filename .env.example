# Banco (Postgres no Railway em dev e prod)
# Crie um Postgres no Railway e cole a connection string aqui
DATABASE_URL="postgresql://user:password@host:5432/repe"

# Better Auth
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET="troque-em-dev-com-openssl-rand-base64-32-caracteres-aaaa"
BETTER_AUTH_URL="http://localhost:3001"

# Frontend (build-time)
VITE_API_URL="http://localhost:3001"
VITE_AUTH_URL="http://localhost:3001"

# Backend
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
